// =============================================================================
// EnadIA TECH - Prisma Schema para Supabase (PostgreSQL)
// =============================================================================
// QUANDO ESTIVER PRONTO PARA MIGRAR:
// 1. Copie este arquivo para schema.prisma (substituindo o atual)
// 2. Configure .env.local com as URLs do Supabase
// 3. Execute: bunx prisma generate && bunx prisma db push
// 4. Execute: bun run prisma/seed.ts && bun run prisma/seed-questions.ts
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  MASTER
  PROFESSOR
  ALUNO
}

enum QuestionType {
  OBJETIVA
  DISSERTATIVA
}

enum QuestionStatus {
  RASCUNHO
  AGUARDANDO_TESTE
  EM_TESTE
  AGUARDANDO_VALIDACAO
  APROVADA
  REPROVADA
  ATIVA
  INATIVA
}

enum SimuladoType {
  DIAGNOSTICO
  MICROAREA
  MACROAREA
  GERAL
  LIVRE
  ENADE_SIMULADO
}

enum Modalidade {
  EAD
  PRESENCIAL
  SEMIPRESENCIAL
}

// ─── MODELS ──────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  password      String
  role          Role         @default(ALUNO)
  ra            String?      @unique
  avatar        String?
  active        Boolean      @default(true)
  lastLogin     DateTime?

  // Student fields
  curso         String?
  periodo       Int?
  modalidade    Modalidade?  @default(PRESENCIAL)

  // Professor fields
  disciplina    String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  responses          StudentResponse[]
  authoredQuestions   Question[]       @relation("QuestionAuthor")
  validatedQuestions Question[]       @relation("QuestionValidator")
  essayAnswers       EssayAnswer[]
}

model Microarea {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  macroarea   String
  description String
  color       String    @default("#3b82f6")
  order       Int       @default(0)
  elements    Element[]
  questions   Question[]
  createdAt   DateTime  @default(now())
}

model Element {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  description  String
  skillLevel   String    @default("compreensão")
  microareaId  String
  microarea    Microarea  @relation(fields: [microareaId], references: [id], onDelete: Cascade)
  order        Int       @default(0)
  questions    Question[]
  createdAt    DateTime  @default(now())
}

model Question {
  id              String         @id @default(cuid())
  code            String         @unique
  type            QuestionType   @default(OBJETIVA)
  statement       String
  context         String?
  correctAnswer   String
  explanation     String?
  difficulty      String         @default("médio")

  triA            Float?
  triB            Float?
  triC            Float?
  triCalibrated   Boolean        @default(false)

  source          String         @default("elaborada")
  sourceYear      Int?
  enadeId         String?

  microareaId     String
  microarea       Microarea      @relation(fields: [microareaId], references: [id])
  elementId       String?
  element         Element?       @relation(fields: [elementId], references: [id])
  authorId        String?
  author          User?          @relation("QuestionAuthor", fields: [authorId], references: [id])
  validatorId     String?
  validator       User?          @relation("QuestionValidator", fields: [validatorId], references: [id])

  status          QuestionStatus @default(RASCUNHO)

  alternatives    Alternative[]
  responses       StudentResponse[]
  simuladoConfigs SimuladoConfig[]
  tags            QuestionTag[]
  essayAnswers    EssayAnswer[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Alternative {
  id         String   @id @default(cuid())
  letter     String
  text       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Simulado {
  id            String        @id @default(cuid())
  title         String
  description   String?
  type          SimuladoType  @default(LIVRE)
  phase         Int?
  timeLimit     Int?
  questionCount Int           @default(10)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  configs       SimuladoConfig[]
  responses     StudentResponse[]
}

model SimuladoConfig {
  id         String   @id @default(cuid())
  simuladoId String
  simulado   Simulado @relation(fields: [simuladoId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int      @default(0)
}

model StudentResponse {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id])
  simuladoId    String?
  simulado      Simulado? @relation(fields: [simuladoId], references: [id])
  answer        String
  isCorrect     Boolean?
  responseTime  Int?
  createdAt     DateTime  @default(now())
}

model EssayAnswer {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id])
  simuladoId    String?
  answer        String
  aiFeedback    String?
  aiScore       Float?
  createdAt     DateTime  @default(now())
}

model QuestionTag {
  id         String   @id @default(cuid())
  name       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
